# ── Environment ──────────────────────────────────────────────────────────────
# Set to "production" on EC2 to enable Secure + SameSite=None cookies
ENVIRONMENT=development

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ── Groq API (optional - for fast LLM-generated answers) ───────────────────────
# Get from https://console.groq.com/keys
# Leave empty to use extractive answers (no API key needed)
GROQ_API_KEY=

# ── LLM (optional) ───────────────────────────────────────────────────────────
# Model to use with Groq (e.g., llama-3.3-70b-versatile, llama3-70b-8192)
LLM_MODEL=llama-3.3-70b-versatile

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ── CORS (your frontend URL) ──────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Frontend URL (OAuth callback redirects here after login) ────────────────
FRONTEND_URL=http://localhost:5173

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=replace-with-a-long-random-string

# ════════════════════════════════════════════════════════════════════════════════
# PRODUCTION DEPLOYMENT (EC2)
# ════════════════════════════════════════════════════════════════════════════════
# Uncomment and update these for production:
#
# ENVIRONMENT=production
# GOOGLE_REDIRECT_URI=https://your-ec2-domain.com/auth/callback
# ALLOWED_ORIGINS=https://your-app.vercel.app
# FRONTEND_URL=https://your-app.vercel.app
# SESSION_SECRET=<run: openssl rand -hex 32>

